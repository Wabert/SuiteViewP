Attribute VB_Name = "mdlDataMap"
Dim mDataMap As ADODB.Recordset
Global Const BookmarkStringDelimiter = "$#$"
Public Sub ClearDataMap()
   Set mDataMap = Nothing
End Sub
Public Function GetDataMap() As ADODB.Recordset
 If mDataMap Is Nothing Then CreateDataMap
 Set GetDataMap = mDataMap
End Function

Private Sub CreateDataMap()
Set mDataMap = New ADODB.Recordset

mDataMap.Fields.Append "TableName", adVarChar, 200
mDataMap.Fields.Append "FieldName", adVarChar, 200
mDataMap.Fields.Append "CobolName", adVarChar, 200
mDataMap.Fields.Append "CommonName", adVarChar, 200
mDataMap.Fields.Append "SegmentID", adVarChar, 200

mDataMap.Fields.Append "DocumentationFolder", adVarChar, 200
mDataMap.Fields.Append "DocumentationFileName", adVarChar, 200
mDataMap.Fields.Append "DocumentationBookmark", adVarChar, 300, adFldIsNullable



mDataMap.Open

LoadPolicySegment01Mapping
LoadPolicySegment02Mapping
LoadPolicySegment03Mapping
LoadPolicySegment04Mapping
LoadPolicySegment59Mapping
LoadPolicySegment65Mapping
LoadPolicySegment66Mapping
LoadPolicySegment75Mapping

End Sub

